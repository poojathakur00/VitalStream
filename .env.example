# .env.example

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# PostgreSQL
POSTGRES_USER=vitalstream
POSTGRES_PASSWORD=vitalstream_dev
POSTGRES_DB=vitalstream
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# AWS S3 (Week 2)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET=vitalstream-data

# Generator
GENERATOR_INTERVAL_SECONDS=2
GENERATOR_NUM_PATIENTS=20